{
  "rust-analyzer.procMacro.enable": true,
  "rust-analyzer.checkOnSave.command": "clippy",
  "rust-analyzer.cargo.allFeatures": true,
  "rust-analyzer.cargo.noDefaultFeatures": false,
  // Auto-open the Plot Viewer for new plots/images from notebooks
  // Note: setting keys can vary slightly across Jupyter extension versions.
  // If VS Code shows these as unknown, use Settings UI to copy exact keys for your version.
  "jupyter.showPlotViewerForPlots": true,
  "jupyter.alwaysShowPlotViewer": true
}
